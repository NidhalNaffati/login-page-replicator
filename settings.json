{
    // ── Apparence (IntelliJ IDEA style) ────────────────────────────
    "workbench.colorTheme": "Rosé Pine",
    "workbench.iconTheme": "a-file-icon-vscode",
    "workbench.tree.indent": 16,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.tabSizing": "shrink",
    "workbench.editor.wrapTabs": false,
    "workbench.sideBar.location": "left",
    "workbench.statusBar.visible": true,
    "workbench.activityBar.location": "default",
    "workbench.layoutControl.enabled": true,
    "window.newWindowDimensions": "maximized",
    "window.menuBarVisibility": "classic",
    "window.commandCenter": false,
    "window.titleBarStyle": "custom",
    "breadcrumbs.enabled": false,
    // ── Couleurs personnalisées (séparateurs visibles) ──────────────
    "workbench.colorCustomizations": {
        "sideBar.border": "#6e6a8680",
        "activityBar.border": "#6e6a8680",
        "panel.border": "#6e6a8680",
        "editorGroup.border": "#6e6a8680",
        "sideBarSectionHeader.border": "#6e6a8650",
        "tab.border": "#6e6a8640",
        "statusBar.border": "#6e6a8680",
        "titleBar.border": "#6e6a8680"
    },
    // ── Éditeur (IntelliJ IDEA style) ──────────────────────────────
    "editor.fontSize": 14,
    "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', 'Consolas', monospace",
    "editor.fontLigatures": true,
    "editor.lineHeight": 1.6,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.rulers": [
        120
    ],
    "editor.wordWrap": "off",
    "editor.minimap.enabled": false,
    // "editor.renderWhitespace": "boundary",
    "editor.renderWhitespace": "none",
    "editor.renderLineHighlight": "all",
    "editor.renderLineHighlightOnlyWhenFocus": false,
    // Brackets & guides
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.guides.indentation": true,
    "editor.matchBrackets": "always",
    "editor.autoClosingBrackets": "always",
    "editor.autoClosingQuotes": "always",
    "editor.autoSurround": "languageDefined",
    // Smart editing (comme IntelliJ)
    "editor.linkedEditing": true,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": false,
    "editor.suggestSelection": "first",
    "editor.suggest.insertMode": "replace",
    "editor.suggest.showMethods": true,
    "editor.suggest.showConstructors": true,
    "editor.suggest.showFields": true,
    "editor.suggest.showVariables": true,
    "editor.suggest.showClasses": true,
    "editor.suggest.showInterfaces": true,
    "editor.suggest.showKeywords": true,
    "editor.acceptSuggestionOnEnter": "on",
    "editor.tabCompletion": "on",
    "editor.parameterHints.enabled": true,
    "editor.inlineSuggest.enabled": true,
    // Inlay hints (IntelliJ show parameter names)
    "editor.inlayHints.enabled": "on",
    "editor.inlayHints.fontSize": 11,
    "java.inlayHints.parameterNames.enabled": "all",
    // Code lens (comme IntelliJ run/debug au-dessus des méthodes)
    "editor.codeLens": true,
    // Smooth scroll & animations
    "editor.smoothScrolling": true,
    "editor.cursorBlinking": "expand",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorStyle": "line",
    "editor.mouseWheelScrollSensitivity": 1.5,
    "workbench.list.smoothScrolling": true,
    // Sticky scroll (comme IntelliJ sticky class/method header)
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.maxLineCount": 5,
    // Folding
    "editor.folding": true,
    "editor.foldingStrategy": "indentation",
    "editor.showFoldingControls": "mouseover",
    "editor.foldingImportsByDefault": true,
    // Line numbers & gutter
    "editor.lineNumbers": "on",
    "editor.glyphMargin": true,
    // Semantic highlighting (IntelliJ-like rich coloring)
    "editor.semanticHighlighting.enabled": true,
    "editor.occurrencesHighlight": "multiFile",
    "editor.selectionHighlight": true,
    // ── Terminal (PowerShell Windows) ──────────────────────────────
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontFamily": "'JetBrains Mono', 'Consolas', monospace",
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.smoothScrolling": true,
    // ── Java / Maven (IntelliJ-like) ───────────────────────────────
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.saveActions.organizeImports": true,
    "java.import.maven.enabled": true,
    "java.format.settings.url": "",
    "java.completion.importOrder": [
        "java",
        "javax",
        "org",
        "com",
        ""
    ],
    "java.completion.favoriteStaticMembers": [
        "org.junit.Assert.*",
        "org.junit.jupiter.api.Assertions.*",
        "org.mockito.Mockito.*"
    ],
    "java.debug.settings.enableRunDebugCodeLens": true,
    "java.refactor.renameFromFileExplorer": "autoApply",
    "maven.terminal.useJavaHome": true,
    "maven.executable.path": "mvn",
    // ── Fichiers ───────────────────────────────────────────────────
    "files.autoSave": "onFocusChange",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.encoding": "utf8",
    "files.useExperimentalFileWatcher": true,
    "files.watcherExclude": {
        "**/target/classes/**": true,
        "**/target/generated-sources/**": true,
        "**/target/generated-test-sources/**": true,
        "**/target/maven-archiver/**": true,
        "**/target/maven-status/**": true,
        "**/target/surefire-reports/**": true,
        "**/target/archive-tmp/**": true,
        "**/target/test-classes/**": true
    },
    "files.exclude": {
        "**/.git": true,
        "**/target/generated-sources": true,
        "**/target/generated-test-sources": true,
        "**/target/maven-archiver": true,
        "**/target/maven-status": true,
        "**/target/surefire-reports": true,
        "**/target/archive-tmp": true
    },
    // ── Recherche ──────────────────────────────────────────────────
    "search.smartCase": true,
    "search.useIgnoreFiles": false,
    "search.exclude": {
        "**/target/classes": true,
        "**/target/generated-sources": true,
        "**/target/generated-test-sources": true,
        "**/target/maven-archiver": true,
        "**/target/maven-status": true,
        "**/target/surefire-reports": true,
        "**/target/archive-tmp": true,
        "**/target/test-classes": true
    },
    // ── Git ────────────────────────────────────────────────────────
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.decorations.enabled": true,
    "scm.diffDecorations": "all",
    "github.copilot.enable": {
        "*": true,
        "java": true,
        "yaml": true,
        "xml": true
    },
    "chat.viewSessions.orientation": "stacked"
}
